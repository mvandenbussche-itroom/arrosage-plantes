// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Plant {
  id            String    @id @default(cuid())
  name          String
  location      String    // ex: "2e étage - open space Nord"
  frequencyDays Int       // fréquence d'arrosage en jours
  imageUrl      String?   // chemin public de la photo de profil (ex: /uploads/plants/xxx.jpg)
  createdAt     DateTime  @default(now())
  waterings     Watering[]
  // Pas de champ QR : le QR est généré à la volée depuis BASE_URL (cf. lib/qr.ts),
  // ce qui met tous les QR à jour automatiquement quand l'URL change.
}

model Watering {
  id        String   @id @default(cuid())
  plantId   String
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  wateredAt DateTime @default(now())
  // pas de user : scan anonyme
}