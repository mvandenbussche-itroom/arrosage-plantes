// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Plant {
  id            String    @id @default(cuid())
  name          String
  location      String    // ex: "2e étage - open space Nord"
  frequencyDays Int       // fréquence d'arrosage en jours
  createdAt     DateTime  @default(now())
  qrCode        String?   // data URL PNG du QR (généré une seule fois, encode l'URL de la fiche)
  waterings     Watering[]
}

model Watering {
  id        String   @id @default(cuid())
  plantId   String
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  wateredAt DateTime @default(now())
  // pas de user : scan anonyme
}