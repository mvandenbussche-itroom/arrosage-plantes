// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Plant {
  id            String    @id @default(cuid())
  name          String
  location      String    // ex: "2e étage - open space Nord"
  frequencyDays Int       // fréquence d'arrosage en jours
  imageUrl      String?   // chemin public de la photo de profil (ex: /uploads/plants/xxx.jpg)
  createdAt     DateTime  @default(now())
  waterings     Watering[]
  // Pas de champ QR : le QR est généré à la volée depuis BASE_URL (cf. lib/qr.ts),
  // ce qui met tous les QR à jour automatiquement quand l'URL change.
}

model Watering {
  id        String   @id @default(cuid())
  plantId   String
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  wateredAt DateTime @default(now())
  // Le scan reste anonyme (userId null) si personne n'est connecté au moment
  // du tap "J'ai arrosé" : voir plan technique §8, on ne veut pas de friction.
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique // restreint à @itroom.fr à l'inscription
  passwordHash String
  createdAt    DateTime   @default(now())
  sessions     Session[]
  waterings    Watering[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique // sha256 du token brut envoyé au client (le cookie ne contient jamais le hash)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}